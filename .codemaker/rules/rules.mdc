## 9. Error Handling Patterns

### Python Scripts
```python
# Pattern 1: Graceful import failure
try:
    import openpyxl
except ImportError:
    openpyxl = None  # check at runtime

# Pattern 2: JSON error reporting
try:
    result = parse(...)
    print(json.dumps({"success": True, ...}))
    return 0
except Exception as exc:
    logger.error("Failed: %s", exc, exc_info=True)
    print(json.dumps({"success": False, "error": str(exc)}))
    return 1

# Pattern 3: Per-item silent failure
for item in items:
    try:
        process(item)
    except Exception as exc:
        logger.warning("Skipping %s: %s", item, exc)
```

### TypeScript
```typescript
// Cross-runtime try/catch with fallback
try {
    const { getLoadablePath } = await import("sqlite-vec");
    _sqliteVecLoad = (db: any) => db.loadExtension(vecPath);
} catch {
    _sqliteVecLoad = null;  // degrade gracefully
}
```

